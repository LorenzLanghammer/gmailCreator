{
    "manifest_version": 3,
    "name": "User-Agent Spoofer",
    "version": "1.0",
    "description": "Spoof User-Agent for HTTP requests and JavaScript",
    "permissions": [
      "declarativeNetRequest",
      "declarativeNetRequestWithHostAccess",
      "activeTab",
      "storage"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "declarative_net_request": {
      "rule_resources": [
        {
          "id": "userAgentSpoof",
          "enabled": true,
          "path": "rules.json"
        }
      ]
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"]
      }
    ],
    "icons": {
   
    }
  }
  